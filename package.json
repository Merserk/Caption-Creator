{
  "name": "caption-creator",
  "version": "11.2.0",
  "description": "Desktop application for generating image captions and tags.",
  "main": "main.js",
  "author": "Merserk",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-win": "electron-builder --win"
  },
  "build": {
    "appId": "com.mm744.captioncreator",
    "productName": "Caption Creator",
    "electronLanguages": [
      "en-US"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "./bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "./config.ini",
        "to": "config.ini"
      },
      {
        "from": "./scripts",
        "to": "scripts",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "./assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/images/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.13.0"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "fs-extra": "^11.3.5"
  },
  "overrides": {
    "glob": "^13.0.6",
    "rimraf": "^6.1.3"
  }
}
